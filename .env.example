# Copy to .env.local for local dev. In production set these in your host (Vercel, AWS, GCP).

# Auth.js: set to true when using ngrok or other proxy URLs so session/auth work
# AUTH_TRUST_HOST=true

# Firebase client config lives in src/lib/constants/firebase.ts (not in .env). For web push only, set VAPID key:
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin (FCM push). Minified one-line JSON from Firebase Console > Service accounts > Generate new private key.
# Local and prod: set in .env (local) or host env vars (Vercel etc.). Single quotes optional: FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cron: secret for /api/cron/* (16+ chars). Set in Vercel env; cron requests send Authorization: Bearer <CRON_SECRET>.
CRON_SECRET= 
