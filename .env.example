# Copy to .env.local for local dev. In production set these in your host (Vercel, AWS, GCP).

# Auth.js: set to true when using ngrok or other proxy URLs so session/auth work
# AUTH_TRUST_HOST=true

# Firebase (client). Get from Firebase Console > Project settings > Your apps. Never commit real keys.
# After changing project or these vars: run "node scripts/generate-firebase-sw.js" and restart dev server.
# Production (Vercel etc.): set ALL NEXT_PUBLIC_FIREBASE_* in the host env so the build runs generate-firebase-sw.js with valid config; otherwise FCM tokens will not be created (public/firebase-messaging-sw.js would have empty config).
# Restrict the API key in Google Cloud Console: APIs & Services > Credentials > Application restrictions (HTTP referrers: your domains only) and API restrictions.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin (FCM push). Minified one-line JSON from Firebase Console > Service accounts > Generate new private key.
# Local and prod: set in .env (local) or host env vars (Vercel etc.). Single quotes optional: FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cron: secret for /api/cron/* (16+ chars). Set in Vercel env; cron requests send Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Owner-only admin dashboard (/admin). Comma-separated emails; only these can access. Not tied to USER/ADMIN role.
ADMIN_DASHBOARD_ALLOWED_EMAILS=
