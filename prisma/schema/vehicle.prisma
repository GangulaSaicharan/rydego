model Vehicle {
  id          String @id @default(cuid())
  ownerId     String

  brand       String
  model       String
  color       String?
  plateNumber String @unique

  seats       Int

  deletedAt   DateTime?

  createdAt   DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id])

  rides Ride[]
}
