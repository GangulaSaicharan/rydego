model Location {
  id String @id @default(uuid())

  city    String
  state   String?
  country String?

  latitude  Float
  longitude Float
  status    Boolean @default(true)
  placeId   String?

  createdAt DateTime @default(now())

  ridesFrom Ride[] @relation("RideFrom")
  ridesTo   Ride[] @relation("RideTo")

  stops RideStop[] @relation("RideStopLocation")
}
