enum RideStatus {
  SCHEDULED
  STARTED
  COMPLETED
  CANCELLED
}

enum GenderPreference {
  NONE
  SAME_GENDER
}

model Ride {
  id String @id @default(uuid())

  driverId  String
  vehicleId String?

  fromLocationId String
  toLocationId   String

  departureTime DateTime
  arrivalTime   DateTime?

  pricePerSeat Decimal @db.Decimal(10, 2)
  currency     String  @default("INR")

  seatsTotal     Int
  seatsAvailable Int

  instantBooking Boolean @default(true)

  genderPreference GenderPreference @default(NONE)

  status RideStatus @default(SCHEDULED)

  description String?

  /// Slot time e.g. "5am to 6am"
  fromSlot String?

  deletedAt DateTime?

  driver User @relation("DriverRides", fields: [driverId], references: [id])

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  fromLocation Location @relation("RideFrom", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("RideTo", fields: [toLocationId], references: [id])

  stops RideStop[]

  bookings Booking[]

  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  views Int @default(0)

  @@index([driverId, status, departureTime])
  @@index([status, departureTime])
  @@index([fromLocationId, toLocationId, departureTime])
  @@index([departureTime])
}

model RideStop {
  id     String @id @default(uuid())
  rideId String

  order     Int
  locationId String

  ride Ride @relation(fields: [rideId], references: [id])

  location Location @relation("RideStopLocation", fields: [locationId], references: [id])

  @@unique([rideId, order])
  @@unique([rideId, locationId])
}
